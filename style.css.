*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
background:linear-gradient(135deg,#0f172a,#020617);
}

.container{
padding:20px;
}

.calculator{
width:380px;
background:rgba(255,255,255,0.08);
backdrop-filter:blur(20px);
border:1px solid rgba(255,255,255,.15);
border-radius:25px;
padding:20px;
box-shadow:0 0 30px rgba(0,0,0,.5);
}

.brand{
text-align:center;
color:#00e5ff;
font-size:28px;
font-weight:700;
letter-spacing:2px;
margin-bottom:15px;
}

#display{
width:100%;
height:70px;
border:none;
outline:none;
background:rgba(255,255,255,.1);
border-radius:15px;
font-size:30px;
color:white;
padding:15px;
text-align:right;
margin-bottom:20px;
}

.buttons{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:12px;
}

button{
height:60px;
border:none;
border-radius:15px;
background:rgba(255,255,255,.08);
color:white;
font-size:20px;
cursor:pointer;
transition:.3s;
}

button:hover{
background:#00e5ff;
color:black;
transform:scale(1.05);
}

.orange{
background:#ff9800;
}

.red{
background:#ff1744;
}
